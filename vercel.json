{
  "installCommand": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1 npm install --no-audit --no-fund --prefer-offline",
  "build": {
    "env": {
      "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/auth/(.*)", "destination": "/auth/$1" },
    { "source": "/_nuxt/(.*)", "destination": "/_nuxt/$1" },
    { "source": "/excalidraw-editor/(.*)", "destination": "/excalidraw-editor/$1" },
    { "source": "/((?!api|auth|_nuxt|excalidraw-editor).*)", "destination": "/index.html" }
  ]
}
